      "updated": 1773735512890,
      "link": null,
      "locked": false,
      "fontSize": 41.299244448442074,
      "fontFamily": 8,
      "text": "1] Minimum Latitude, Maximum Latitude\n2] Minimum Longitude, Maximum Longitude\n3] Leaf Node Business Points\n4] Tok-K Business Points. [To scale further decouple this data to Redis] \n5] Tok-K Business Points by category like Cafe, Pizza, etc. [To scale further decouple this data to Redis.] \n\n",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1] Minimum Latitude, Maximum Latitude\n2] Minimum Longitude, Maximum Longitude\n3] Leaf Node Business Points\n4] Tok-K Business Points. [To scale further decouple this data to Redis] \n5] Tok-K Business Points by category like Cafe, Pizza, etc. [To scale further decouple this data to Redis.] \n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
