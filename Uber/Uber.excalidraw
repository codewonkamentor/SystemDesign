      "boundElements": null,
      "updated": 1773826125562,
      "link": null,
      "locked": false,
      "text": "API-Endpoints: 5Min\n\n1] API_NAME:  POST - book_ride  \n\nA} Input: {\n      user_id,\n      source_longitude,\n      source_latitude,\n      destination address: {\n      street_name: ,\n      city,\n      country,\n      zip code\n      }\nB} SyncOutput: {\n      requestId: ,\n      status: searching,\n      eta:,\n      amount: \n      }\n}\n\n\nC} AsyncOutput: {\n      driver_id: ,\n      driver_name:,\n      car_details: {\n      car_number: ,\n      car_color:,\n      car_make:,\n      amount: \n      }\n}\n\n\n] API_NAME:  POST - payment  \n\nA} Input: {\n    {\n       user_id,\n       payment_details: {\n       payer_name:\n       payer_address:,\n       payment_type: {\n       type: card\n       card number: ,\n       card expirt\n   }\n},\n       source_latitude,\n       destination address: {\n       street_name: ,\n       city,\n       country,\n       zip code\n}\n\nB} Output: {\n      transaction_id: ,\n      payment_status:,\n      amount_processed: \n      payment_request_time: \n      }\n}\n\n",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API-Endpoints: 5Min\n\n1] API_NAME:  POST - book_ride  \n\nA} Input: {\n      user_id,\n      source_longitude,\n      source_latitude,\n      destination address: {\n      street_name: ,\n      city,\n      country,\n      zip code\n      }\nB} SyncOutput: {\n      requestId: ,\n      status: searching,\n      eta:,\n      amount: \n      }\n}\n\n\nC} AsyncOutput: {\n      driver_id: ,\n      driver_name:,\n      car_details: {\n      car_number: ,\n      car_color:,\n      car_make:,\n      amount: \n      }\n}\n\n\n] API_NAME:  POST - payment  \n\nA} Input: {\n    {\n       user_id,\n       payment_details: {\n       payer_name:\n       payer_address:,\n       payment_type: {\n       type: card\n       card number: ,\n       card expirt\n   }\n},\n       source_latitude,\n       destination address: {\n       street_name: ,\n       city,\n       country,\n       zip code\n}\n\nB} Output: {\n      transaction_id: ,\n      payment_status:,\n      amount_processed: \n      payment_request_time: \n      }\n}\n\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
