      "link": null,
      "locked": false,
      "text": "API-Endpoints: 5Min\n\n1] API_NAME:  POST - book_session\n\nA} Input: {\n          \n          recruiter_id, \n          candidate_id,\n          candidate_name, \n          ... candidate metadata\n          start-date, \n          end_date,\n          start time, \n          end time,\n          \n          ...\n      }\nB} SyncOutput: {\n          status: Sucess/Failed\n          start-date, \n          end_date,\n          start time, \n          end time,\n          recruiter_id, \n      }\n}\n\n\n2] API_NAME:  POST - get_security_url\n\nA} Input: {\n          \n          recruiter_id, \n          start-date, \n          ...\n      }\nB} SyncOutput: {\n          url (string):  \n      }\n}\n\n\n\n\nOAUTH with Trust relations",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API-Endpoints: 5Min\n\n1] API_NAME:  POST - book_session\n\nA} Input: {\n          \n          recruiter_id, \n          candidate_id,\n          candidate_name, \n          ... candidate metadata\n          start-date, \n          end_date,\n          start time, \n          end time,\n          \n          ...\n      }\nB} SyncOutput: {\n          status: Sucess/Failed\n          start-date, \n          end_date,\n          start time, \n          end time,\n          recruiter_id, \n      }\n}\n\n\n2] API_NAME:  POST - get_security_url\n\nA} Input: {\n          \n          recruiter_id, \n          start-date, \n          ...\n      }\nB} SyncOutput: {\n          url (string):  \n      }\n}\n\n\n\n\nOAUTH with Trust relations",
      "autoResize": false,
      "lineHeight": 1.25
    },
