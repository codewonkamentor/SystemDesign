    {
      "type": "text",
      "version": 7326,
      "versionNonce": 1192910982,
      "index": "btM",
      "isDeleted": false,
      "id": "DRoQoo5F4WU0nA2uc1NES",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 4369.765142295637,
      "y": 5963.449629215387,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "width": 1385.891357421875,
