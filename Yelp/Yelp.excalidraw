    {
      "type": "text",
      "version": 2303,
      "versionNonce": 1937383471,
      "index": "bBl",
      "isDeleted": false,
      "id": "Jo1sBo8qmp1gWCPrfJbjc",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "x": 1371.3348125893172,
      "y": 4740.724124356002,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "width": 2191.034912109375,
      "height": 558.9526888368671,
