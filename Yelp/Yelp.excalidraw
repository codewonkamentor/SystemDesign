      "fontSize": 37.2469620972023,
      "fontFamily": 8,
      "text": "SELECT b.*\nFROM GeoBusinessMap gbm\nJOIN Businesses bus\n  ON gbm.business_id = bus.business_id\nWHERE gbm.geo_hash IN ('c22yz',\n'c22yw', 'c22yx', 'c22yt', 'c22yv');",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SELECT b.*\nFROM GeoBusinessMap gbm\nJOIN Businesses bus\n  ON gbm.business_id = bus.business_id\nWHERE gbm.geo_hash IN ('c22yz', 'c22yw', 'c22yx', 'c22yt', 'c22yv');",
      "autoResize": false,
      "lineHeight": 1.25
    },
